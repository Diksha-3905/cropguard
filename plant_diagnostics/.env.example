# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── Supabase ──────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...  # Backend only — never in Flutter

# ── AI Services ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DEEPGRAM_API_KEY=...         # For STT (Phase 2)
ELEVENLABS_API_KEY=...       # For TTS (Phase 2)
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL  # Default voice — change as needed

# ── Backend URL (for Flutter) ─────────────────
BACKEND_URL=https://your-worker.railway.app

# ── Railway deploy token (for CI) ─────────────
RAILWAY_TOKEN=...

# ── Flutter build (pass via --dart-define) ────
# flutter build apk \
#   --dart-define=SUPABASE_URL=$SUPABASE_URL \
#   --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY \
#   --dart-define=BACKEND_URL=$BACKEND_URL
